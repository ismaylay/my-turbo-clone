{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/vehicle-listing.json",
  "title": "VehicleListing",
  "description": "Structured document for automotive marketplace listings (Turbo.az–style).",
  "type": "object",
  "required": [
    "id",
    "priceAmount",
    "currency",
    "make",
    "model",
    "year",
    "condition",
    "createdAt"
  ],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "slug": { "type": "string" },
    "isPremium": { "type": "boolean", "default": false },
    "isVerified": { "type": "boolean", "default": false },
    "isSalon": { "type": "boolean", "default": false },
    "priceAmount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "enum": ["AZN", "USD", "EUR"] },
    "make": { "type": "string" },
    "model": { "type": "string" },
    "trim": { "type": "string" },
    "year": { "type": "integer", "minimum": 1950, "maximum": 2035 },
    "condition": { "type": "string", "enum": ["new", "used"] },
    "bodyType": { "type": "string" },
    "engineVolumeL": { "type": "number" },
    "engineLabel": { "type": "string" },
    "horsepower": { "type": "integer" },
    "mileageKm": { "type": "integer", "minimum": 0 },
    "gearbox": { "type": "string", "enum": ["manual", "automatic", "robot", "cvt"] },
    "fuelType": { "type": "string", "enum": ["petrol", "diesel", "hybrid", "electric", "lpg"] },
    "locationCity": { "type": "string" },
    "locationCountry": { "type": "string", "default": "AZ" },
    "creditAvailable": { "type": "boolean", "default": false },
    "barterAvailable": { "type": "boolean", "default": false },
    "imageUrls": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 1
    },
    "thumbnailUrl": { "type": "string", "format": "uri" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "sellerId": { "type": "string" },
    "viewCount": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
